# =============================================
# Google Ads API - Облікові дані
# =============================================
# Скопіюйте цей файл у .env та заповніть всі значення
# Див. SETUP_GUIDE.md для деталей як отримати кожне значення
#
# 1. GOOGLE_ADS_DEVELOPER_TOKEN
#    З вашого Google Ads Manager Account (MCC)
#    Google Ads → Tools & Settings → API Center
#
# 2. GOOGLE_ADS_CLIENT_ID & GOOGLE_ADS_CLIENT_SECRET
#    З Google Cloud Console
#    APIs & Services → Credentials → OAuth 2.0 Client ID
#
# 3. GOOGLE_ADS_REFRESH_TOKEN
#    Отримується через OAuth 2.0 Playground
#    https://developers.google.com/oauthplayground/
#
# 4. GOOGLE_ADS_CUSTOMER_ID
#    ID вашого рекламного кабінету (Google Ads)
#    Формат: 123-456-7890
#
# 5. GOOGLE_ADS_LOGIN_CUSTOMER_ID (опціонально)
#    ID вашого MCC акаунта якщо керуєте кількома акаунтами
# =============================================

GOOGLE_ADS_DEVELOPER_TOKEN=
GOOGLE_ADS_CLIENT_ID=
GOOGLE_ADS_CLIENT_SECRET=
GOOGLE_ADS_REFRESH_TOKEN=
GOOGLE_ADS_CUSTOMER_ID=
# GOOGLE_ADS_LOGIN_CUSTOMER_ID=
