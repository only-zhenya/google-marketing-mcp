# =============================================
# Google Ads API - Облікові дані
# =============================================
# Скопіюйте цей файл у .env та заповніть всі значення
# Див. SETUP_GUIDE.md для деталей як отримати кожне значення
#
# 1. GOOGLE_ADS_DEVELOPER_TOKEN
#    🔗 https://ads.google.com/home/tools/manager-accounts/
#    → Tools & Settings → API Center
#
# 2. GOOGLE_ADS_CLIENT_ID & GOOGLE_ADS_CLIENT_SECRET
#    🔗 https://console.cloud.google.com/apis/credentials
#    → Create Credentials → OAuth 2.0 Client ID → Web application
#
# 3. GOOGLE_ADS_REFRESH_TOKEN
#    🔗 https://developers.google.com/oauthplayground/
#    Scopes:
#      https://www.googleapis.com/auth/adwords
#      https://www.googleapis.com/auth/webmasters.readonly
#      https://www.googleapis.com/auth/analytics.readonly
#      https://www.googleapis.com/auth/tagmanager.edit
#
# 4. GOOGLE_ADS_CUSTOMER_ID
#    🔗 https://ads.google.com/
#    → Tools & Settings → Account access (на лічильнику в лівому меню)
#    Формат: 123-456-7890 або 1234567890
#
# 5. GOOGLE_ADS_LOGIN_CUSTOMER_ID (опціонально)
#    🔗 https://ads.google.com/home/tools/manager-accounts/
#    ID вашого Manager Account (MCC), якщо керуєте кількома акаунтами
# =============================================

GOOGLE_ADS_DEVELOPER_TOKEN=
GOOGLE_ADS_CLIENT_ID=
GOOGLE_ADS_CLIENT_SECRET=
GOOGLE_ADS_REFRESH_TOKEN=
GOOGLE_ADS_CUSTOMER_ID=
# GOOGLE_ADS_LOGIN_CUSTOMER_ID=
